{
  "version": 2,
  "builds": [
    {
      "src": "importexportproject/wsgi.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "importexportproject/wsgi.py"
    }
  ],
  "scripts": {
    "vercel-build": "python3 -m pip install -r requirements.txt && python3 manage.py migrate"
  }
}